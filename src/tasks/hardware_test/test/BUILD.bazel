load("//bzl:defs.bzl", "samwise_test")

package(default_visibility = ["//visibility:public"])

# In BRINGUP/PICO builds: compiles test sources so hardware_test_task can call
# the registered entry points (e.g. mram_test_main).
# In test (host) builds: exposes only the headers so samwise_test targets can
# include hardware_test_assert.h and hardware_tests.h without pulling in
# firmware-only sources.
cc_library(
    name = "hardware_test_lib",
    srcs = select({
        "//bzl:test_mode": [],
        "//conditions:default": ["mram_test.c"],
    }),
    hdrs = [
        "hardware_test_assert.h",
        "hardware_tests.h",
    ],
    includes = ["."],
    deps = select({
        "//bzl:test_mode": [],
        "//conditions:default": [
            "//src/common",
            "//src/drivers/logger",
            "//src/drivers/mram",
            "@pico-sdk//src/rp2_common/pico_stdlib:pico_stdlib",
        ],
    }),
)

samwise_test(
    name = "mram_test",
    srcs = ["mram_test.c"],
    deps = [
        ":hardware_test_lib",
        "//src/common",
        "//src/drivers/logger",
        "//src/drivers/mram",
        "@pico-sdk//src/rp2_common/pico_stdlib:pico_stdlib",
    ],
)
