# Test mocks for Pico-SDK hardware abstractions
# These mocks replace embedded hardware dependencies with test-friendly implementations

package(default_visibility = ["//visibility:public"])

# Pico stdlib mock (standard library functions for Pico)
cc_library(
    name = "pico_stdlib_mock",
    hdrs = [
        "pico/stdlib.h",
        "pico/types.h",
        "pico/unique_id.h",
        "pico/util/queue.h",
    ],
    testonly = True,
    includes = ["."],
)

# Hardware SPI mock
cc_library(
    name = "hardware_spi_mock",
    hdrs = ["hardware/spi.h"],
    testonly = True,
    includes = ["."],
)

# Hardware I2C mock
cc_library(
    name = "hardware_i2c_mock",
    hdrs = ["hardware/i2c.h"],
    testonly = True,
    includes = ["."],
)

# Hardware PWM mock
cc_library(
    name = "hardware_pwm_mock",
    hdrs = ["hardware/pwm.h"],
    testonly = True,
    includes = ["."],
)

# Hardware GPIO mock
cc_library(
    name = "hardware_gpio_mock",
    hdrs = ["hardware/gpio.h"],
    testonly = True,
    includes = ["."],
)

# Hardware Flash mock
cc_library(
    name = "hardware_flash_mock",
    hdrs = ["hardware/flash.h"],
    testonly = True,
    includes = ["."],
)

# Hardware Resets mock
cc_library(
    name = "hardware_resets_mock",
    hdrs = ["hardware/resets.h"],
    testonly = True,
    includes = ["."],
)

# Hardware Sync mock
cc_library(
    name = "hardware_sync_mock",
    hdrs = ["hardware/sync.h"],
    testonly = True,
    includes = ["."],
)

# Pico time mock (timing functions)
cc_library(
    name = "pico_time_mock",
    srcs = ["pico/time.c"],
    hdrs = ["pico/time.h"],
    testonly = True,
    includes = ["."],
    deps = [":pico_stdlib_mock"],
)

# Complete test mocks library (aggregates all Pico SDK hardware mocks)
cc_library(
    name = "test_mocks",
    testonly = True,
    deps = [
        ":hardware_flash_mock",
        ":hardware_gpio_mock",
        ":hardware_i2c_mock",
        ":hardware_pwm_mock",
        ":hardware_resets_mock",
        ":hardware_spi_mock",
        ":hardware_sync_mock",
        ":pico_stdlib_mock",
        ":pico_time_mock",
    ],
)
