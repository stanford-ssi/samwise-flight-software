# Test mocks for Pico-SDK hardware abstractions
# These mocks replace embedded hardware dependencies with test-friendly implementations

package(default_visibility = ["//visibility:public"])

# Pico stdlib mock (standard library functions for Pico)
cc_library(
    name = "pico_stdlib_mock",
    hdrs = [
        "pico/stdlib.h",
        "pico/types.h",
        "pico/unique_id.h",
        "pico/util/queue.h",
    ],
    testonly = True,
    includes = ["."],
)

# Hardware SPI mock
cc_library(
    name = "hardware_spi_mock",
    hdrs = ["hardware/spi.h"],
    testonly = True,
    includes = ["."],
)

# Hardware I2C mock
cc_library(
    name = "hardware_i2c_mock",
    hdrs = ["hardware/i2c.h"],
    testonly = True,
    includes = ["."],
)

# Hardware PWM mock
cc_library(
    name = "hardware_pwm_mock",
    hdrs = ["hardware/pwm.h"],
    testonly = True,
    includes = ["."],
)

# Hardware GPIO mock
cc_library(
    name = "hardware_gpio_mock",
    hdrs = ["hardware/gpio.h"],
    testonly = True,
    includes = ["."],
)

# Hardware Flash mock
cc_library(
    name = "hardware_flash_mock",
    hdrs = ["hardware/flash.h"],
    testonly = True,
    includes = ["."],
)

# Hardware Resets mock
cc_library(
    name = "hardware_resets_mock",
    hdrs = ["hardware/resets.h"],
    testonly = True,
    includes = ["."],
)

# Hardware Sync mock
cc_library(
    name = "hardware_sync_mock",
    hdrs = ["hardware/sync.h"],
    testonly = True,
    includes = ["."],
)

# Pico time mock (timing functions)
cc_library(
    name = "pico_time_mock",
    srcs = ["pico/time.c"],
    hdrs = ["pico/time.h"],
    testonly = True,
    includes = ["."],
    deps = [":pico_stdlib_mock"],
)

# Logger mock (SAMWISE driver mock)
cc_library(
    name = "logger_mock",
    srcs = ["logger.c"],
    testonly = True,
    includes = ["."],
)

# Neopixel mock (SAMWISE driver mock)
cc_library(
    name = "neopixel_mock",
    srcs = ["neopixel.c"],
    hdrs = ["neopixel.h"],
    testonly = True,
    includes = ["."],
)

# Error handling mock (SAMWISE module mock)
cc_library(
    name = "error_mock",
    srcs = ["error.c"],
    hdrs = ["error.h"],
    testonly = True,
    includes = ["."],
)

# Driver stubs (generic driver mocks)
cc_library(
    name = "driver_stubs",
    srcs = ["driver_stubs.c"],
    testonly = True,
    includes = ["."],
)

# State mocks (for state machine testing)
cc_library(
    name = "state_mocks",
    hdrs = [
        "bringup_state.h",
        "burn_wire_reset_state.h",
        "burn_wire_state.h",
        "init_state.h",
        "running_state.h",
        "states.h",
    ],
    testonly = True,
    includes = ["."],
)

# Complete test mocks library (aggregates all mocks)
cc_library(
    name = "test_mocks",
    testonly = True,
    deps = [
        ":driver_stubs",
        ":error_mock",
        ":hardware_flash_mock",
        ":hardware_gpio_mock",
        ":hardware_i2c_mock",
        ":hardware_pwm_mock",
        ":hardware_resets_mock",
        ":hardware_spi_mock",
        ":hardware_sync_mock",
        ":logger_mock",
        ":neopixel_mock",
        ":pico_stdlib_mock",
        ":pico_time_mock",
        ":state_mocks",
    ],
)
